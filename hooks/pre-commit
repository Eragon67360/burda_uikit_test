
#!/bin/sh

npm run format
if [ $? -ne 0 ]; then
  echo "Formatting failed. Aborting commit."
  exit 1
fi

npm run lint
if [ $? -ne 0 ]; then
  echo "ESLint failed. Aborting commit."
  exit 1
fi

npm run build
if [ $? -ne 0 ]; then
  echo "Build failed. Aborting commit."
  exit 1
fi

npm audit
if [ $? -ne 0 ]; then
  echo "Audit. Aborting commit."
  exit 1
fi

exit 0
