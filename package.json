{
  "name": "nodejs_burda_uikit",
  "version": "1.1.0",
  "scripts": {
    "test": "test-storybook",
    "watch:tailwindcss": "npx @tailwindcss/cli -i ./tailwind.css -o ./.storybook/tailwind.css --watch",
    "watch:storybook": "storybook dev -p 6006",
    "build": "storybook build",
    "dev": "concurrently --kill-others \"npm run watch:tailwindcss\" \"npm run watch:storybook\"",
    "preview-storybook": "serve storybook-static -s -l 6007",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "preinstall": "git config core.hooksPath hooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://bitbucket.org:avenit/nodejs_burda_uikit.git"
  },
  "author": "avenit AG",
  "license": "UNLICENSED",
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@eslint/js": "^9.24.0",
    "@eslint/json": "^0.11.0",
    "@storybook/addon-a11y": "^8.6.12",
    "@storybook/addon-backgrounds": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-styling-webpack": "^1.0.1",
    "@storybook/addon-webpack5-compiler-swc": "^2.1.0",
    "@storybook/blocks": "^8.6.12",
    "@storybook/html": "^8.6.12",
    "@storybook/html-webpack5": "^8.6.12",
    "@storybook/manager-api": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@storybook/test-runner": "^0.22.0",
    "@storybook/theming": "^8.6.12",
    "@swc/core": "^1.11.21",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.13.10",
    "autoprefixer": "^10.4.20",
    "axe-playwright": "^2.1.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "storybook": "^8.6.12",
    "tailwindcss": "^4.0.6",
    "typescript-eslint": "^8.29.1"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.6",
    "flowbite": "^3.1.2",
    "hammerjs": "^2.0.8",
    "tsconfig-paths-webpack-plugin": "^4.2.0"
  }
}
